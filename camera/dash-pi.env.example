# Dash-Pi Example Configuration
#
# Copy this file to dash-pi.env and edit as needed.
# All values can be overridden by environment variables.
#
# Common options are shown below, commented out with defaults.
#
# To run: ./dash-pi-rs-aarch64 (or dash-pi-rs-armv7) in this directory.
#
# For more info, see README.md or https://github.com/your-repo-link

# --- Camera settings ---
#WIDTH=1280
#HEIGHT=720
#FRAMERATE=30
#BITRATE=2000000           # Bits per second (2 Mbps)
#CLIP_LENGTH=5             # Minutes per segment
#OUTPUT=./media            # Output directory for recordings
#PICAM_APP=libcamera-vid   # Camera command

# --- Web server ---
#WEB_ENABLED=true
#WEB_ROOT=dashboard        # Folder to serve (relative to this directory)
#WEB_PORT=8080

# --- Storage management ---
#MIN_FREE_MB=500           # Minimum free space before deleting old files

# --- Preview (live snapshot) ---
#PREVIEW_ENABLED=true
#PREVIEW_INTERVAL=2        # Seconds between preview frames

# --- Camera tuning (optional) ---
#VFLIP=false
#HFLIP=false
#METERING=average
#DENOISE=off
#EXPOSURE=normal
#AF_MODE=manual
#AF_RANGE=normal
#LENS_POSITION=0.0
#HDR=off

# --- Advanced ---
#EXTRA_CAM_ARGS=           # Any extra args for the camera command

# --- Getting Started ---
# 1. Copy this file to .env and edit as needed.
# 2. Run the binary for your platform (see above).
# 3. Open the dashboard in your browser: http://<pi-ip>:8080/
#
# For more help, see the README or ask for support!
